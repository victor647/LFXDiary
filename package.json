{
  "name": "lfxdiary",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "browser:dev": "vite --host 127.0.0.1 --port 5173 --strictPort --open",
    "browser:start": "node packaging/scripts/start-browser-dev.cjs",
    "browser:stop": "node packaging/scripts/stop-browser-dev.cjs",
    "build": "tsc -b && vite build",
    "nas:build": "npm run build && node packaging/scripts/prepare-nas-dist.cjs",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "desktop:pack": "npm run desktop:pack:win",
    "desktop:pack:win": "npm run build && electron-builder --dir --win --config.directories.output=dist",
    "desktop:pack:mac": "npm run build && electron-builder --dir --mac --x64",
    "desktop:dist": "npm run desktop:dist:win",
    "desktop:dist:win": "npm run build && electron-builder --win --config.directories.output=dist",
    "desktop:dist:mac": "npm run build && electron-builder --mac --x64",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "cn.lafaxi.lfxdiary",
    "productName": "Diary Book",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "build/icon.icns",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "packaging/build/installer.nsh"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "minimumSystemVersion": "11.0.0",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "isomorphic-git": "^1.38.5",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "37.10.3",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
